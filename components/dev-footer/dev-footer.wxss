.dev-footer {
  margin-top: 40rpx;
  padding: 28rpx 24rpx;
  background: #faf6f0;
  border-radius: 12rpx;
  border: 1rpx solid #eadfce;
  text-align: center;
}

.dev-footer.compact {
  margin-top: 24rpx;
  padding: 20rpx 16rpx;
}

.dev-line {
  font-size: 26rpx;
  color: #8B4513;
  font-weight: 600;
  line-height: 1.5;
}

.dev-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}

.dev-btn {
  display: inline-block;
  margin-top: 20rpx;
  padding: 12rpx 36rpx;
  font-size: 24rpx;
  color: #8B4513;
  border: 2rpx solid #8B4513;
  border-radius: 999rpx;
}
