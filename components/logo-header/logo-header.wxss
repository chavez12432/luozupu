.logo-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 24rpx 16rpx 8rpx;
}

.logo-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(196, 30, 30, 0.2);
}

.size-sm .logo-img { width: 96rpx; height: 96rpx; }
.size-lg .logo-img { width: 220rpx; height: 220rpx; }

.logo-title {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #2C2416;
  letter-spacing: 6rpx;
}

.size-sm .logo-title { font-size: 28rpx; letter-spacing: 3rpx; margin-top: 12rpx; }
.size-lg .logo-title { font-size: 40rpx; }

.logo-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #C19A4B;
  letter-spacing: 4rpx;
}

.logo-motto {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #C41E1E;
  letter-spacing: 8rpx;
  font-weight: 600;
}

.gold-line {
  margin-top: 20rpx;
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #C19A4B, transparent);
}
