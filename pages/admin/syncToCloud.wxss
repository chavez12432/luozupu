.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.content {
  padding: 0 20rpx;
}

.stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #07c160;
  display: block;
}

.stat-label {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
  display: block;
}

.stat-arrow {
  font-size: 40rpx;
  color: #999;
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary {
  background-color: #07c160;
  color: #fff;
}

.btn-primary[disabled] {
  background-color: #999;
}

.btn-success {
  background-color: #10aeff;
  color: #fff;
}

.btn-danger {
  background-color: #ff4d4f;
  color: #fff;
}

.btn-danger[disabled] {
  background-color: #999;
}

.progress-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.progress-bar {
  width: 100%;
  height: 20rpx;
  background-color: #e0e0e0;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #07c160;
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #07c160;
  padding-left: 20rpx;
}

.info-content {
  display: flex;
  flex-direction: column;
}

.info-content text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.error-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
  margin-bottom: 20rpx;
}

.error-list {
  max-height: 400rpx;
}

.error-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.error-text {
  font-size: 28rpx;
  color: #666;
}
