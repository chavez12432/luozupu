<view class="auth-page">
  <view class="auth-card">
    <view class="auth-title">绑定手机与微信</view>
    <view class="auth-desc">
      <text class="desc-line">身份验证已通过{{personName ? '：' + personName : ''}}。</text>
      <text class="desc-line">请绑定手机号完成注册。微信账号将自动关联。</text>
    </view>

    <block wx:if="{{!isLocal}}">
      <button
        class="auth-btn auth-btn-primary phone-btn"
        open-type="getPhoneNumber|agreePrivacyAuthorization"
        bindgetphonenumber="onGetPhoneNumber"
        bindagreeprivacyauthorization="onAgreePrivacy"
        loading="{{loading}}"
        disabled="{{loading}}"
      >微信一键授权手机号</button>
      <view class="auth-hint">点击上方按钮后，请在弹出窗口中允许获取手机号</view>

      <view class="or-divider"><text>或手动填写</text></view>
      <text class="auth-label">手机号</text>
      <input
        class="auth-input"
        type="number"
        maxlength="11"
        placeholder="请输入11位手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
      <view
        class="auth-btn auth-btn-primary"
        bindtap="bindManualPhone"
      >确认绑定</view>
    </block>

    <block wx:else>
      <text class="auth-label">手机号（本地调试）</text>
      <input
        class="auth-input"
        type="number"
        maxlength="11"
        placeholder="请输入11位手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
      <view class="auth-btn auth-btn-primary" bindtap="bindManualPhone">完成绑定</view>
    </block>

    <view wx:if="{{error}}" class="error-box">
      <text class="error-text">{{error}}</text>
    </view>

    <dev-footer compact="{{true}}"></dev-footer>
  </view>
</view>
