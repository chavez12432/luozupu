<view class="auth-page">
  <view class="auth-card">
    <view class="auth-title">姓名验证</view>
    <view class="auth-desc">请输入您的名字（不用输入姓氏）\n例如：华强</view>

    <text class="auth-label">名字</text>
    <input
      class="auth-input"
      placeholder="请输入名字"
      value="{{name}}"
      bindinput="onNameInput"
      maxlength="20"
    />
    <view class="auth-hint">族谱库中姓名均为名（不含「罗」姓）</view>

    <view wx:if="{{error}}" class="error-box">
      <text class="error-text">{{error}}</text>
    </view>

    <view class="auth-btn auth-btn-primary" bindtap="submit">下一步</view>
    <view wx:if="{{canAppeal}}" class="auth-btn auth-btn-ghost" bindtap="goAppeal">人工申诉</view>

    <dev-footer compact="{{true}}"></dev-footer>
  </view>
</view>
