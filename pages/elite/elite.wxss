/* pages/elite/elite.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  color: white;
  background: #9B1515;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.35);
}

.header-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.92;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.3);
}

.content {
  padding: 30rpx;
  height: calc(100vh - 260rpx);
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.elite-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.elite-item {
  background: white;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.08);
}

.elite-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #fff0f2;
  color: #f5576c;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.elite-info {
  flex: 1;
}

.elite-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.elite-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
  align-items: center;
}

.branch-text {
  font-size: 22rpx;
  color: #f5576c;
  background: #fff0f2;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.gen-text {
  font-size: 22rpx;
  color: #999;
}

.elite-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 12rpx;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  justify-content: center;
  gap: 60rpx;
  padding: 16rpx;
  border-top: 1rpx solid #eee;
}

.nav-item {
  display: flex;
  align-items: center;
  color: #667eea;
}

.nav-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.nav-text {
  font-size: 26rpx;
}
