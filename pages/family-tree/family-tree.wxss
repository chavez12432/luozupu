/* pages/family-tree/family-tree.wxss */
/* 与荣誉堂等栏目一致：整页纵向 flex，底栏贴底不飘移 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F7E8D0;
  box-sizing: border-box;
  overflow: hidden;
}

.header {
  flex-shrink: 0;
  background: linear-gradient(165deg, #C41E1E 0%, #9B1515 100%);
  color: #fff;
  padding: 36rpx 30rpx 40rpx;
  text-align: center;
}

.header-logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 3rpx solid #C19A4B;
  margin-bottom: 12rpx;
  background: #FFF9F0;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
}

.header-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.9;
  letter-spacing: 3rpx;
}

.hub-body {
  flex: 1;
  min-height: 0;
  padding: 28rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.hall-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.hall-card {
  background: #FFF9F0;
  border-radius: 16rpx;
  padding: 28rpx 22rpx;
  box-shadow: 0 8rpx 24rpx rgba(44, 36, 22, 0.1);
  border: 2rpx solid rgba(193, 154, 75, 0.45);
}

.hall-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C2416;
}

.hall-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8A7A64;
}

.hall-count {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #5C4E3A;
}

.hall-action {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #C41E1E;
}

.hub-tip {
  margin-top: 28rpx;
  padding: 20rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #5C4E3A;
  background: #FFF9F0;
  border-radius: 12rpx;
  border-left: 6rpx solid #C41E1E;
}

.chart-header {
  flex-shrink: 0;
  background: #5d4037;
  color: #fff;
  padding: 20rpx 24rpx 16rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}

.chart-stats {
  margin-top: 6rpx;
  font-size: 20rpx;
  text-align: center;
  opacity: 0.88;
}

.chart-tools {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tool-btn {
  padding: 8rpx 18rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tool-scale {
  font-size: 22rpx;
  min-width: 80rpx;
  text-align: center;
}

.chart-scroll {
  flex: 1;
  min-height: 0;
  height: 0;
  background: #fffef9;
}

.chart-stage {
  position: relative;
}

.pedigree-canvas {
  display: block;
  background: #fffef9;
}

.loading,
.chart-loading {
  flex: 1;
  text-align: center;
  padding: 80rpx;
  color: #999;
}
