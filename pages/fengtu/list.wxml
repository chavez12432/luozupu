<view class="container">
  <scenic-nav title="风土志" scene="fengtu"></scenic-nav>
  <view class="header scenic-header">
    <image class="scenic-header__bg" src="/images/headers/fengtu.jpg" mode="aspectFill" />
    <view class="scenic-header__mask"></view>
    <view class="scenic-header__body">
      <text class="title">风土志</text>
      <text class="subtitle">堂记 · 祠宇 · 八景</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view class="preface-list" wx:else>
    <view
      class="preface-item"
      wx:for="{{items}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="goToDetail"
    >
      <view class="item-number">{{index + 1}}</view>
      <view class="item-content">
        <text class="item-title">{{item.title}}</text>
        <view class="item-meta">
          <view class="meta-row">
            <text class="meta-item" wx:if="{{item.authorName}}">作者：{{item.authorName}}</text>
            <text class="meta-item" wx:if="{{item.year}}">公元：{{item.year}}</text>
          </view>
        </view>
        <text class="item-summary">{{item.summary}}</text>
      </view>
      <view class="item-arrow">›</view>
    </view>
  </view>

  <clan-tabbar active="honor"></clan-tabbar>
</view>
