/* pages/graduates/graduates.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
  padding: 30rpx;
  text-align: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

.header-sub {
  font-size: 24rpx;
  margin-top: 8rpx;
  opacity: 0.85;
}

.type-tabs {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.type-tab {
  padding: 10rpx 18rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.type-tab.active {
  background: white;
  color: #2389d8;
}

.tab-count {
  font-size: 20rpx;
  opacity: 0.85;
}

.content {
  padding: 30rpx;
  height: calc(100vh - 320rpx);
  box-sizing: border-box;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.honor-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.honor-item {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
}

.honor-item:active {
  background: #f7fbff;
}

.honor-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.honor-name.link {
  color: #2389d8;
  text-decoration: underline;
}

.honor-row {
  display: flex;
  align-items: flex-start;
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.honor-row .label {
  width: 140rpx;
  flex-shrink: 0;
  color: #999;
}

.honor-row .value {
  flex: 1;
  color: #444;
}

.title-tag {
  color: #c45c26;
  font-weight: 600;
}

.edu-block {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.edu-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.edu-display {
  flex: 1;
  color: #333;
  line-height: 1.5;
}

.edu-degree {
  min-width: 88rpx;
  padding: 2rpx 12rpx;
  background: #e8f6ff;
  color: #2389d8;
  border-radius: 8rpx;
  text-align: center;
  font-size: 22rpx;
}

.edu-school {
  flex: 1;
  color: #555;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  justify-content: center;
  gap: 60rpx;
  padding: 16rpx;
  border-top: 1rpx solid #eee;
}

.nav-item {
  display: flex;
  align-items: center;
  color: #667eea;
}

.nav-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.nav-text {
  font-size: 26rpx;
}
