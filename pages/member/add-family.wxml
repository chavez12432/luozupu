<view class="page">
  <view class="card">
    <view class="title">添加{{relationLabel}}</view>

    <text class="label">姓名（不用输入姓氏）</text>
    <input class="input" value="{{name}}" bindinput="onName" placeholder="如：建国" />

    <text class="label">性别</text>
    <picker mode="selector" range="{{genders}}" value="{{genderIndex}}" bindchange="onGenderChange">
      <view class="picker">{{genders[genderIndex]}}</view>
    </picker>

    <view class="btn primary" bindtap="submit">确认添加</view>
  </view>
</view>
