.page {
  min-height: 100vh;
  background: #f5f0e8;
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #8B4513;
  margin: 16rpx 0 8rpx;
}

.input, .picker {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e8ddd0;
  border-radius: 10rpx;
  background: #faf8f5;
  font-size: 28rpx;
}

.btn {
  margin-top: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.btn.primary {
  background: linear-gradient(135deg, #8B4513, #A0522D);
  color: #fff;
}
