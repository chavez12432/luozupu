<!--pages/member/detail.wxml-->
<scroll-view scroll-y class="container">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:else class="detail-content">
    <view wx:if="{{member.hasBrokenLineage}}" class="broken-alert">
      <text class="alert-icon">⚠️</text>
      <text class="alert-text">历史断层成员</text>
    </view>

    <view wx:if="{{permission.locked}}" class="manage-lock">
      <text>{{permission.lockReason}}</text>
    </view>

    <view
      wx:elif="{{permission.canEdit || permission.canAddChild || permission.canAddSpouse || permission.canDelete}}"
      class="manage-bar"
    >
      <view wx:if="{{permission.canEdit}}" class="manage-btn" bindtap="goEdit">编辑资料</view>
      <view wx:if="{{permission.canAddChild}}" class="manage-btn" bindtap="goAddChild">添加子女</view>
      <view wx:if="{{permission.canAddSpouse}}" class="manage-btn" bindtap="goAddSpouse">添加配偶</view>
      <view wx:if="{{permission.canDelete}}" class="manage-btn danger" bindtap="confirmDelete">删除</view>
    </view>

    <!-- ========== 古代人详情 · 册档风 ========== -->
    <block wx:if="{{!member.isModern}}">
      <view class="ag-page">
        <view class="ag-hero">
          <view class="ag-seal">{{member.name[0]}}</view>
          <view class="ag-hero-meta">
            <text class="ag-era">家族档案 · 古人</text>
            <text class="ag-name">{{member.name}}</text>
            <view class="ag-tags">
              <text class="ag-tag">{{member.gender || '—'}}</text>
              <text class="ag-tag accent">第{{member.generation}}世</text>
              <text class="ag-tag">{{member.branch || '—'}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{member.hasBrokenLineage}}" class="ag-panel ag-broken">
          <view class="ag-panel-head">
            <view class="ag-panel-bar"></view>
            <text class="ag-panel-title">断层说明</text>
          </view>
          <text class="broken-desc">{{member.brokenLineageNote || '—'}}</text>
        </view>

        <view class="ag-panel">
          <view class="ag-panel-head">
            <view class="ag-panel-bar"></view>
            <text class="ag-panel-title">荣誉</text>
          </view>
          <view class="ag-honor-tags" wx:if="{{member.honorsList && member.honorsList.length}}">
            <text wx:for="{{member.honorsList}}" wx:key="*this" class="ag-honor-tag">{{item}}</text>
          </view>
          <text wx:else class="ag-empty">—</text>
        </view>

        <view class="ag-panel">
          <view class="ag-panel-head">
            <view class="ag-panel-bar"></view>
            <text class="ag-panel-title">基本信息</text>
          </view>
          <view class="ag-kv">
            <text class="ag-kv-k">性别</text>
            <text class="ag-kv-v">{{member.gender || '—'}}</text>
          </view>
          <view class="ag-kv">
            <text class="ag-kv-k">世代</text>
            <text class="ag-kv-v">第{{member.generation}}世</text>
          </view>
          <view class="ag-kv">
            <text class="ag-kv-k">分堂</text>
            <text class="ag-kv-v">{{member.branch || '—'}}</text>
          </view>
          <view class="ag-kv">
            <text class="ag-kv-k">居住地</text>
            <text class="ag-kv-v">{{member.residence || '—'}}</text>
          </view>
        </view>

        <view class="ag-panel">
          <view class="ag-panel-head">
            <view class="ag-panel-bar"></view>
            <text class="ag-panel-title">生卒</text>
            <text class="ag-panel-hint" wx:if="{{member.lifespanText}}">寿 {{member.lifespanText}}</text>
          </view>
          <view class="ag-life-row">
            <view class="ag-life-card birth">
              <text class="ag-life-glyph">生</text>
              <view class="ag-life-line">
                <text class="ag-life-k">日期</text>
                <text class="ag-life-v">{{member.birthDate || '—'}}</text>
              </view>
              <view class="ag-life-line">
                <text class="ag-life-k">朝代</text>
                <text class="ag-life-v">{{member.birthDynasty || '—'}}</text>
              </view>
              <view class="ag-life-line">
                <text class="ag-life-k">干支</text>
                <text class="ag-life-v">{{member.birthGanzhi || '—'}}</text>
              </view>
              <view class="ag-life-line">
                <text class="ag-life-k">生肖</text>
                <text class="ag-life-v">{{member.birthZodiac || '—'}}</text>
              </view>
            </view>
            <view class="ag-life-card death">
              <text class="ag-life-glyph">卒</text>
              <view class="ag-life-line">
                <text class="ag-life-k">日期</text>
                <text class="ag-life-v">{{member.deathDate || '—'}}</text>
              </view>
              <view class="ag-life-line">
                <text class="ag-life-k">朝代</text>
                <text class="ag-life-v">{{member.deathDynasty || '—'}}</text>
              </view>
              <view class="ag-life-line">
                <text class="ag-life-k">干支</text>
                <text class="ag-life-v">{{member.deathGanzhi || '—'}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="ag-panel">
          <view class="ag-panel-head">
            <view class="ag-panel-bar"></view>
            <text class="ag-panel-title">亲缘</text>
          </view>
          <view class="kin-grid">
            <!-- 父 -->
            <navigator
              wx:if="{{member.fatherId}}"
              open-type="redirect"
              url="/pages/member/detail?id={{member.fatherId}}"
              class="kin-card link"
              hover-class="link-hover"
            >
              <text class="kin-role">父亲</text>
              <text class="kin-name">{{member.fatherName}}</text>
              <text class="kin-chevron">›</text>
            </navigator>
            <view wx:elif="{{member.fatherName}}" class="kin-card">
              <text class="kin-role">父亲</text>
              <text class="kin-name">{{member.fatherName}}</text>
            </view>
            <view wx:else class="kin-card empty">
              <text class="kin-role">父亲</text>
              <text class="kin-name muted">—</text>
            </view>

            <!-- 母 -->
            <navigator
              wx:if="{{member.motherWifeId}}"
              url="/pages/wife-detail/wife-detail?id={{member.motherWifeId}}"
              class="kin-card link"
              hover-class="link-hover"
            >
              <text class="kin-role">母亲</text>
              <text class="kin-name">{{member.motherName}}</text>
              <text class="kin-chevron">›</text>
            </navigator>
            <navigator
              wx:elif="{{member.motherId}}"
              open-type="redirect"
              url="/pages/member/detail?id={{member.motherId}}"
              class="kin-card link"
              hover-class="link-hover"
            >
              <text class="kin-role">母亲</text>
              <text class="kin-name">{{member.motherName}}</text>
              <text class="kin-chevron">›</text>
            </navigator>
            <view wx:elif="{{member.motherName}}" class="kin-card">
              <text class="kin-role">母亲</text>
              <text class="kin-name">{{member.motherName}}</text>
            </view>
            <view wx:else class="kin-card empty">
              <text class="kin-role">母亲</text>
              <text class="kin-name muted">—</text>
            </view>
          </view>

          <!-- 配偶 -->
          <view class="kin-section-label">配偶</view>
          <view class="kin-grid kin-grid-wrap">
            <block wx:if="{{member.gender !== '女'}}">
              <block wx:if="{{member.wives && member.wives.length > 0}}">
                <block wx:for="{{member.wives}}" wx:key="linkId">
                  <navigator
                    wx:if="{{item.linkType === 'member'}}"
                    open-type="redirect"
                    url="/pages/member/detail?id={{item.linkId}}"
                    class="kin-card link"
                    hover-class="link-hover"
                  >
                    <text class="kin-role">{{item.marriageType && item.marriageType !== '配' ? item.marriageType : '配偶'}}</text>
                    <text class="kin-name">{{item.name}}<text wx:if="{{item.isClanSpouse || item.hometown === '本村'}}" class="clan-tag">本村</text></text>
                    <text class="kin-chevron">›</text>
                  </navigator>
                  <navigator
                    wx:elif="{{item.linkType === 'wife'}}"
                    url="/pages/wife-detail/wife-detail?id={{item.linkId}}"
                    class="kin-card link"
                    hover-class="link-hover"
                  >
                    <text class="kin-role">{{item.marriageType && item.marriageType !== '配' ? item.marriageType : '配偶'}}</text>
                    <text class="kin-name">{{item.name}}</text>
                    <text class="kin-chevron">›</text>
                  </navigator>
                </block>
              </block>
              <view wx:else class="kin-card empty">
                <text class="kin-role">配偶</text>
                <text class="kin-name muted">—</text>
              </view>
            </block>
            <block wx:else>
              <block wx:if="{{member.husbands && member.husbands.length > 0}}">
                <navigator
                  wx:for="{{member.husbands}}"
                  wx:key="linkId"
                  open-type="redirect"
                  url="/pages/member/detail?id={{item.linkId}}"
                  class="kin-card link"
                  hover-class="link-hover"
                >
                  <text class="kin-role">配偶</text>
                  <text class="kin-name">{{item.name}}<text wx:if="{{item.isClanSpouse}}" class="clan-tag">本村</text></text>
                  <text class="kin-chevron">›</text>
                </navigator>
              </block>
              <navigator
                wx:elif="{{member.spouseMemberDocId}}"
                open-type="redirect"
                url="/pages/member/detail?id={{member.spouseMemberDocId}}"
                class="kin-card link"
                hover-class="link-hover"
              >
                <text class="kin-role">配偶</text>
                <text class="kin-name">{{member.spouseName}}</text>
                <text class="kin-chevron">›</text>
              </navigator>
              <view wx:else class="kin-card empty">
                <text class="kin-role">配偶</text>
                <text class="kin-name muted">—</text>
              </view>
            </block>
          </view>

          <!-- 子女 -->
          <view class="kin-section-label">子女</view>
          <view class="kin-grid kin-grid-wrap">
            <block wx:if="{{member.children && member.children.length > 0}}">
              <navigator
                wx:for="{{member.children}}"
                wx:key="_id"
                open-type="redirect"
                url="/pages/member/detail?id={{item._id}}"
                class="kin-card link"
                hover-class="link-hover"
              >
                <text class="kin-role">{{item.gender === '男' ? '子' : '女'}} · 第{{item.generation}}世</text>
                <text class="kin-name">{{item.name}}</text>
                <text class="kin-chevron">›</text>
              </navigator>
            </block>
            <view wx:else class="kin-card empty">
              <text class="kin-role">子女</text>
              <text class="kin-name muted">—</text>
            </view>
          </view>
        </view>

        <view class="ag-panel">
          <view class="ag-panel-head">
            <view class="ag-panel-bar"></view>
            <text class="ag-panel-title">功名官职</text>
          </view>
          <view class="ag-kv">
            <text class="ag-kv-k">功名</text>
            <text class="ag-kv-v">{{member.gongming || '—'}}</text>
          </view>
          <view class="ag-kv">
            <text class="ag-kv-k">官职</text>
            <text class="ag-kv-v">{{member.guanzhi || '—'}}</text>
          </view>
        </view>

        <view class="ag-panel">
          <view class="ag-panel-head">
            <view class="ag-panel-bar"></view>
            <text class="ag-panel-title">墓葬</text>
          </view>
          <view class="ag-kv">
            <text class="ag-kv-k">墓葬地</text>
            <text class="ag-kv-v">{{member.burialPlace || '—'}}</text>
          </view>
        </view>

        <view class="ag-panel ag-remark">
          <view class="ag-panel-head">
            <view class="ag-panel-bar"></view>
            <text class="ag-panel-title">个人详情</text>
          </view>
          <text class="ag-remark-text">{{member.remark || '暂无记述'}}</text>
        </view>

        <view
          class="ag-panel"
          wx:if="{{member.gender === '女' && member.sonsInLaw && member.sonsInLaw.length}}"
        >
          <view class="ag-panel-head">
            <view class="ag-panel-bar"></view>
            <text class="ag-panel-title">女婿</text>
          </view>
          <view class="kin-grid kin-grid-wrap">
            <block wx:for="{{member.sonsInLaw}}" wx:key="_id">
              <navigator
                wx:if="{{item.linkType === 'member' && item.linkId}}"
                open-type="redirect"
                url="/pages/member/detail?id={{item.linkId}}"
                class="kin-card link"
                hover-class="link-hover"
              >
                <text class="kin-role">女婿</text>
                <text class="kin-name">{{item.name}}<text wx:if="{{item.isSameVillage}}" class="clan-tag">本村</text></text>
                <text class="kin-chevron">›</text>
              </navigator>
              <view wx:else class="kin-card">
                <text class="kin-role">女婿</text>
                <text class="kin-name">{{item.name}}</text>
              </view>
            </block>
          </view>
        </view>
      </view>
    </block>

    <!-- ========== 现代人详情 · 档案卡风 ========== -->
    <block wx:else>
      <view class="md-page">
        <view class="md-hero">
          <view class="md-hero-ornament"></view>
          <view class="md-hero-body">
            <view class="md-portrait" bindtap="choosePhoto">
              <image wx:if="{{member.photo}}" class="md-portrait-img" src="{{member.photo}}" mode="aspectFill" />
              <view wx:else class="md-portrait-empty">
                <text class="md-portrait-seal">{{member.name[0]}}</text>
                <text class="md-portrait-tip">{{permission.canEdit ? '点此上传' : '暂无相片'}}</text>
              </view>
              <view class="md-portrait-frame"></view>
            </view>
            <view class="md-hero-meta">
              <text class="md-era">家族档案 · 今人</text>
              <text class="md-name">{{member.name}}</text>
              <view class="md-tags">
                <text class="md-tag">{{member.gender}}</text>
                <text class="md-tag accent">第{{member.generation}}世</text>
                <text class="md-tag">{{member.branch}}</text>
              </view>
              <view class="md-reside" wx:if="{{member.residence}}">
                <text class="md-reside-label">现居</text>
                <text class="md-reside-val">{{member.residence}}</text>
              </view>
            </view>
          </view>
          <view
            class="md-honor-ribbon"
            wx:if="{{member.honorsList && member.honorsList.length}}"
          >
            <text class="md-honor-mark">誉</text>
            <view class="md-honor-texts">
              <text wx:for="{{member.honorsList}}" wx:key="*this" class="md-honor-line">{{item}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{member.hasBrokenLineage}}" class="md-panel md-broken">
          <view class="md-panel-head">
            <view class="md-panel-bar"></view>
            <text class="md-panel-title">断层说明</text>
          </view>
          <text class="broken-desc">{{member.brokenLineageNote || ''}}</text>
        </view>

        <view class="md-panel">
          <view class="md-panel-head">
            <view class="md-panel-bar"></view>
            <text class="md-panel-title">联络</text>
          </view>
          <view class="md-contact-grid">
            <view class="md-contact-cell">
              <text class="md-contact-label">手机</text>
              <view class="md-contact-row">
                <text
                  wx:if="{{member.phone}}"
                  class="md-contact-val link"
                  data-phone="{{member.phone}}"
                  bindtap="onCallPhone"
                >{{member.phone}}</text>
                <text wx:else class="md-contact-val muted">未绑定</text>
                <text
                  wx:if="{{permission.canEdit}}"
                  class="md-mini-btn"
                  data-type="phone"
                  bindtap="onBindContact"
                >{{member.phone ? '更换' : '绑定'}}</text>
              </view>
            </view>
            <view class="md-contact-cell">
              <text class="md-contact-label">微信</text>
              <view class="md-contact-row">
                <text
                  wx:if="{{member.wechat}}"
                  class="md-contact-val link"
                  data-wechat="{{member.wechat}}"
                  bindtap="onCopyWechat"
                >{{member.wechat}}</text>
                <text wx:else class="md-contact-val muted">未绑定</text>
                <text
                  wx:if="{{permission.canEdit}}"
                  class="md-mini-btn"
                  data-type="wechat"
                  bindtap="onBindContact"
                >{{member.wechat ? '更换' : '绑定'}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="md-life-row">
          <view class="md-life-panel birth">
            <view class="md-life-head">
              <text class="md-life-glyph">生</text>
              <text class="md-life-sub" wx:if="{{member.lifespanText}}">寿 {{member.lifespanText}}</text>
            </view>
            <view class="md-life-line">
              <text class="md-life-k">公历</text>
              <text class="md-life-v">{{member.birthDateGregorian || '—'}}</text>
            </view>
            <view class="md-life-line">
              <text class="md-life-k">农历</text>
              <text class="md-life-v">{{member.birthDateLunar || '—'}}</text>
            </view>
            <view class="md-life-line">
              <text class="md-life-k">干支</text>
              <text class="md-life-v">{{member.birthGanzhi || '—'}}</text>
            </view>
            <view class="md-life-chips">
              <text class="md-chip" wx:if="{{member.constellation}}">{{member.constellation}}</text>
              <text class="md-chip" wx:if="{{member.birthZodiac}}">属{{member.birthZodiac}}</text>
            </view>
          </view>
          <view class="md-life-panel death">
            <view class="md-life-head">
              <text class="md-life-glyph">卒</text>
            </view>
            <view class="md-life-line">
              <text class="md-life-k">公历</text>
              <text class="md-life-v">{{member.deathDateGregorian || '—'}}</text>
            </view>
            <view class="md-life-line">
              <text class="md-life-k">农历</text>
              <text class="md-life-v">{{member.deathDateLunar || '—'}}</text>
            </view>
            <view class="md-life-line">
              <text class="md-life-k">干支</text>
              <text class="md-life-v">{{member.deathGanzhi || '—'}}</text>
            </view>
          </view>
        </view>

        <!-- 亲缘横卡（无树状连线） -->
        <view class="md-panel">
          <view class="md-panel-head">
            <view class="md-panel-bar"></view>
            <text class="md-panel-title">亲缘</text>
          </view>
          <view class="kin-grid">
            <navigator
              wx:if="{{member.fatherId}}"
              open-type="redirect"
              url="/pages/member/detail?id={{member.fatherId}}"
              class="kin-card link"
              hover-class="link-hover"
            >
              <text class="kin-role">父亲</text>
              <text class="kin-name">{{member.fatherName}}</text>
              <text class="kin-chevron">›</text>
            </navigator>
            <view wx:elif="{{member.fatherName}}" class="kin-card">
              <text class="kin-role">父亲</text>
              <text class="kin-name">{{member.fatherName}}</text>
            </view>
            <view wx:else class="kin-card empty">
              <text class="kin-role">父亲</text>
              <text class="kin-name muted">—</text>
            </view>

            <navigator
              wx:if="{{member.motherWifeId}}"
              url="/pages/wife-detail/wife-detail?id={{member.motherWifeId}}"
              class="kin-card link"
              hover-class="link-hover"
            >
              <text class="kin-role">母亲</text>
              <text class="kin-name">{{member.motherName}}</text>
              <text class="kin-chevron">›</text>
            </navigator>
            <navigator
              wx:elif="{{member.motherId}}"
              open-type="redirect"
              url="/pages/member/detail?id={{member.motherId}}"
              class="kin-card link"
              hover-class="link-hover"
            >
              <text class="kin-role">母亲</text>
              <text class="kin-name">{{member.motherName}}</text>
              <text class="kin-chevron">›</text>
            </navigator>
            <view wx:elif="{{member.motherName}}" class="kin-card">
              <text class="kin-role">母亲</text>
              <text class="kin-name">{{member.motherName}}</text>
            </view>
            <view wx:else class="kin-card empty">
              <text class="kin-role">母亲</text>
              <text class="kin-name muted">—</text>
            </view>
          </view>

          <view class="kin-section-label">配偶</view>
          <view class="kin-grid kin-grid-wrap">
            <block wx:if="{{member.gender !== '女'}}">
              <block wx:if="{{member.wives && member.wives.length}}">
                <block wx:for="{{member.wives}}" wx:key="linkId">
                  <navigator
                    wx:if="{{item.linkType === 'member'}}"
                    open-type="redirect"
                    url="/pages/member/detail?id={{item.linkId}}"
                    class="kin-card link"
                    hover-class="link-hover"
                  >
                    <text class="kin-role">配偶</text>
                    <text class="kin-name">{{item.name}}<text wx:if="{{item.isClanSpouse || item.hometown === '本村'}}" class="clan-tag">本村</text></text>
                    <text class="kin-chevron">›</text>
                  </navigator>
                  <navigator
                    wx:elif="{{item.linkType === 'wife'}}"
                    url="/pages/wife-detail/wife-detail?id={{item.linkId}}"
                    class="kin-card link"
                    hover-class="link-hover"
                  >
                    <text class="kin-role">配偶</text>
                    <text class="kin-name">{{item.name}}</text>
                    <text class="kin-chevron">›</text>
                  </navigator>
                </block>
              </block>
              <view wx:else class="kin-card empty">
                <text class="kin-role">配偶</text>
                <text class="kin-name muted">—</text>
              </view>
            </block>
            <block wx:else>
              <block wx:if="{{member.husbands && member.husbands.length}}">
                <navigator
                  wx:for="{{member.husbands}}"
                  wx:key="linkId"
                  open-type="redirect"
                  url="/pages/member/detail?id={{item.linkId}}"
                  class="kin-card link"
                  hover-class="link-hover"
                >
                  <text class="kin-role">配偶</text>
                  <text class="kin-name">{{item.name}}<text wx:if="{{item.isClanSpouse}}" class="clan-tag">本村</text></text>
                  <text class="kin-chevron">›</text>
                </navigator>
              </block>
              <navigator
                wx:elif="{{member.spouseMemberDocId}}"
                open-type="redirect"
                url="/pages/member/detail?id={{member.spouseMemberDocId}}"
                class="kin-card link"
                hover-class="link-hover"
              >
                <text class="kin-role">配偶</text>
                <text class="kin-name">{{member.spouseName}}</text>
                <text class="kin-chevron">›</text>
              </navigator>
              <view wx:else class="kin-card empty">
                <text class="kin-role">配偶</text>
                <text class="kin-name muted">—</text>
              </view>
            </block>
          </view>

          <view class="kin-section-label">子女</view>
          <view class="kin-grid kin-grid-wrap">
            <block wx:if="{{member.children && member.children.length}}">
              <navigator
                wx:for="{{member.children}}"
                wx:key="_id"
                open-type="redirect"
                url="/pages/member/detail?id={{item._id}}"
                class="kin-card link"
                hover-class="link-hover"
              >
                <text class="kin-role">{{item.gender === '男' ? '子' : '女'}}</text>
                <text class="kin-name">{{item.name}}</text>
                <text class="kin-chevron">›</text>
              </navigator>
            </block>
            <view wx:else class="kin-card empty">
              <text class="kin-role">子女</text>
              <text class="kin-name muted">—</text>
            </view>
          </view>
        </view>

        <view class="md-panel">
          <view class="md-panel-head">
            <view class="md-panel-bar"></view>
            <text class="md-panel-title">学业与履历</text>
          </view>
          <view class="md-lines-block">
            <text class="md-lines-caption">学历</text>
            <block wx:if="{{member.educationList && member.educationList.length}}">
              <text
                wx:for="{{member.educationList}}"
                wx:key="display"
                class="md-line-item"
              >{{item.line}}</text>
            </block>
            <text wx:else class="md-line-item muted">—</text>
          </view>
          <view class="md-divider"></view>
          <view class="md-lines-block">
            <text class="md-lines-caption">工作</text>
            <block wx:if="{{member.jobList && member.jobList.length}}">
              <text
                wx:for="{{member.jobList}}"
                wx:key="display"
                class="md-line-item"
              >{{item.line}}</text>
            </block>
            <text wx:else class="md-line-item muted">—</text>
          </view>
          <view class="md-divider" wx:if="{{member.honorsList && member.honorsList.length}}"></view>
          <view class="md-lines-block" wx:if="{{member.honorsList && member.honorsList.length}}">
            <text class="md-lines-caption">荣誉</text>
            <text
              wx:for="{{member.honorsList}}"
              wx:key="*this"
              class="md-line-item"
            >{{item}}</text>
          </view>
        </view>

        <view class="md-panel">
          <view class="md-panel-head">
            <view class="md-panel-bar"></view>
            <text class="md-panel-title">墓葬</text>
          </view>
          <view class="md-kv">
            <text class="md-kv-k">墓葬地</text>
            <text class="md-kv-v">{{member.burialPlace || '—'}}</text>
          </view>
          <view class="md-kv">
            <text class="md-kv-k">GPS</text>
            <view class="md-kv-v row">
              <text>{{member.burialGps || '—'}}</text>
              <text
                wx:if="{{member.burialGps}}"
                class="md-mini-btn"
                bindtap="onOpenBurialGps"
              >导航</text>
            </view>
          </view>
        </view>

        <view class="md-panel md-manuscript">
          <view class="md-panel-head">
            <view class="md-panel-bar"></view>
            <text class="md-panel-title">个人详情</text>
          </view>
          <text class="md-manuscript-text">{{member.remark || '暂无记述'}}</text>
        </view>

        <view
          class="md-panel"
          wx:if="{{member.gender === '女' && member.sonsInLaw && member.sonsInLaw.length}}"
        >
          <view class="md-panel-head">
            <view class="md-panel-bar"></view>
            <text class="md-panel-title">女婿</text>
          </view>
          <view class="kin-grid kin-grid-wrap">
            <block wx:for="{{member.sonsInLaw}}" wx:key="_id">
              <navigator
                wx:if="{{item.linkType === 'member' && item.linkId}}"
                open-type="redirect"
                url="/pages/member/detail?id={{item.linkId}}"
                class="kin-card link"
                hover-class="link-hover"
              >
                <text class="kin-role">女婿</text>
                <text class="kin-name">{{item.name}}<text wx:if="{{item.isSameVillage}}" class="clan-tag">本村</text></text>
                <text class="kin-chevron">›</text>
              </navigator>
              <view wx:else class="kin-card">
                <text class="kin-role">女婿</text>
                <text class="kin-name">{{item.name}}</text>
              </view>
            </block>
          </view>
        </view>

        <view class="md-panel md-gallery">
          <view class="md-panel-head">
            <view class="md-panel-bar"></view>
            <text class="md-panel-title">家族相片</text>
            <text class="md-panel-hint">最多 10 张</text>
          </view>
          <view class="md-gallery-grid" wx:if="{{member.photoGalleryList && member.photoGalleryList.length}}">
            <image
              wx:for="{{member.photoGalleryList}}"
              wx:key="*this"
              class="md-gallery-item"
              src="{{item}}"
              mode="aspectFill"
              data-index="{{index}}"
              bindtap="onPreviewGallery"
            />
          </view>
          <view wx:else class="md-gallery-empty">
            <view class="md-gallery-empty-frame"></view>
            <text>暂无家族相片</text>
          </view>
        </view>
      </view>
    </block>

    <view class="action-buttons">
      <button wx:if="{{member.hasBrokenLineage}}" class="btn btn-clue" bindtap="submitClue">
        提供寻亲线索
      </button>
      <button class="btn btn-back" bindtap="goBack">返回</button>
    </view>

    <dev-footer></dev-footer>
  </view>
</scroll-view>

<canvas
  wx:if="{{showPhotoCanvas}}"
  canvas-id="photoCropCanvas"
  class="photo-crop-canvas"
  style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
></canvas>
