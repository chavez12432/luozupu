/* pages/patriarchs/patriarchs.wxss */
.container {
  min-height: 100vh;
  background-color: #faf8f5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #8b4513 0%, #a0522d 100%);
  color: white;
  padding: 40rpx;
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
}

.header-sub {
  font-size: 24rpx;
  margin-top: 8rpx;
  opacity: 0.8;
}

.content {
  padding: 30rpx;
}

.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.patriarch-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.patriarch-item {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.patriarch-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.patriarch-info {
  flex: 1;
}

.patriarch-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #8b4513;
}

.patriarch-title {
  font-size: 26rpx;
  color: #666;
  margin: 8rpx 0;
}

.patriarch-meta {
  display: flex;
  gap: 16rpx;
  margin: 8rpx 0;
}

.branch-tag {
  background: #8b4513;
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.achievement {
  color: #c4a47a;
  font-size: 24rpx;
}

.patriarch-achievements {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  justify-content: center;
  gap: 60rpx;
  padding: 16rpx;
  border-top: 1rpx solid #eee;
}

.nav-item {
  display: flex;
  align-items: center;
  color: #667eea;
}

.nav-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.nav-text {
  font-size: 26rpx;
}
