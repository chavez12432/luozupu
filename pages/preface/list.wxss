.container {
  min-height: 100vh;
  background-color: #F7E8D0;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.header {
  background: linear-gradient(165deg, #C41E1E 0%, #9B1515 100%);
  padding: 40rpx 30rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
  letter-spacing: 6rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

.preface-list {
  padding: 20rpx;
}

.preface-item {
  display: flex;
  align-items: flex-start;
  background: #FFF9F0;
  border: 2rpx solid rgba(193, 154, 75, 0.4);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(44, 36, 22, 0.08);
}

.item-number {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: #C41E1E;
  color: #fff;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-right: 20rpx;
  border: 2rpx solid #C19A4B;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2416;
}

.item-meta {
  margin-top: 12rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 6rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #8A7A64;
}

.item-summary {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #5C4E3A;
  line-height: 1.5;
}

.item-arrow {
  font-size: 36rpx;
  color: #C19A4B;
  margin-left: 8rpx;
}
