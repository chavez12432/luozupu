<view class="container">
  <!-- 头部信息 -->
  <view class="header">
    <text class="title">{{title}}</text>
    <view class="author-info">
      <view class="info-row">
        <view class="info-item">
          <text class="info-label">作者</text>
          <text class="info-value">{{authorName}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">世系</text>
          <text class="info-value">{{authorGeneration}}</text>
        </view>
      </view>
      <view class="info-row">
        <view class="info-item">
          <text class="info-label">朝代</text>
          <text class="info-value">{{dynasty}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">公元</text>
          <text class="info-value">{{year}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 标签切换 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{activeTab === 'original' ? 'active' : ''}}" 
      data-tab="original"
      bindtap="switchTab"
    >
      <text>古文原文</text>
    </view>
    <view 
      class="tab-item {{activeTab === 'translation' ? 'active' : ''}}" 
      data-tab="translation"
      bindtap="switchTab"
    >
      <text>现代译文</text>
    </view>
    <view 
      class="tab-item {{activeTab === 'notes' ? 'active' : ''}}" 
      data-tab="notes"
      bindtap="switchTab"
    >
      <text>考评注释</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <scroll-view class="content-area" scroll-y>
    <!-- 古文原文 -->
    <view class="content-section" wx:if="{{activeTab === 'original'}}">
      <view class="section-title">原文</view>
      <text class="original-text">{{content.original}}</text>
    </view>

    <!-- 现代译文 -->
    <view class="content-section" wx:if="{{activeTab === 'translation'}}">
      <view class="section-title">现代文翻译</view>
      <text class="translation-text">{{content.translation}}</text>
    </view>

    <!-- 考证注释 -->
    <view class="content-section" wx:if="{{activeTab === 'notes'}}">
      <view class="section-title">考评与注释</view>
      <rich-text class="notes-text" nodes="{{content.notesHtml}}"></rich-text>
    </view>
  </scroll-view>
</view>