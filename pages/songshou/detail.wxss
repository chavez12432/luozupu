.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 头部信息 */
.header {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  padding: 30rpx;
  flex-shrink: 0;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

/* 作者信息分栏样式 */
.author-info {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-item {
  display: flex;
  align-items: center;
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-right: 12rpx;
  min-width: 60rpx;
}

.info-value {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
}

/* 标签切换 */
.tab-bar {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-bottom: 1rpx solid #e0e0e0;
  flex-shrink: 0;
  padding: 0 20rpx;
}

.tab-item {
  flex: 0 0 auto;
  text-align: center;
  padding: 24rpx 30rpx;
  position: relative;
  min-width: 160rpx;
}

.tab-item text {
  font-size: 28rpx;
  color: #666;
  white-space: nowrap;
}

.tab-item.active text {
  color: #8B4513;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: #8B4513;
  border-radius: 2rpx;
}

/* 内容区域 */
.content-area {
  flex: 1;
  padding: 20rpx;
}

.content-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0e6dc;
}

/* 古文原文样式 */
.original-text {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 2;
  text-align: justify;
  font-family: "SimSun", "STSong", serif;
}

/* 现代译文样式 */
.translation-text {
  display: block;
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
  text-align: justify;
}

/* 考证注释样式 */
.notes-text {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  text-align: justify;
}

/* 考证注释中的标题粗体显示 */
.notes-text .note-title {
  font-weight: bold;
  color: #333;
}

/* 响应式优化 */
@media (prefers-color-scheme: dark) {
  .container {
    background-color: #1a1a1a;
  }
  
  .content-section {
    background: #2a2a2a;
  }
  
  .original-text {
    color: #e0e0e0;
  }
  
  .translation-text {
    color: #d0d0d0;
  }
  
  .notes-text {
    color: #c0c0c0;
  }
}