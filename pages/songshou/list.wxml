<view class="container">
  <scenic-nav title="颂寿篇" scene="songshou"></scenic-nav>
  <view class="header scenic-header">
    <image class="scenic-header__bg" src="/images/headers/songshou.jpg" mode="aspectFill" />
    <view class="scenic-header__mask"></view>
    <view class="scenic-header__body">
      <text class="title">颂寿篇</text>
      <text class="subtitle">高洲罗氏历代寿序</text>
    </view>
  </view>

  <view class="preface-list">
    <view
      class="preface-item"
      wx:for="{{items}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToDetail"
    >
      <view class="item-number">{{item.id}}</view>
      <view class="item-content">
        <text class="item-title">{{item.title}}</text>
        <view class="item-meta">
          <view class="meta-row">
            <text class="meta-item">作者：{{item.authorName}}</text>
            <text class="meta-item">世系：{{item.authorGeneration}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-item">朝代：{{item.dynasty}}</text>
            <text class="meta-item">公元：{{item.year}}</text>
          </view>
        </view>
        <text class="item-summary">{{item.summary}}</text>
      </view>
      <view class="item-arrow">›</view>
    </view>
  </view>

  <clan-tabbar active="honor"></clan-tabbar>
</view>
