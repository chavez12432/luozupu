/**pages/wife-detail/wife-detail.wxss**/
/* 主容器 */
.container {
  height: 100vh;
  width: 100%;
  background: linear-gradient(180deg, #f5f0e8 0%, #ebe5d9 100%);
  box-sizing: border-box;
}

.loading {
  text-align: center;
  padding: 200rpx;
  color: #999;
}

/* 内容区域 */
.detail-content {
  padding: 20rpx;
  min-height: calc(100vh - 40rpx);
  display: flex;
  flex-direction: column;
}

/* 基本信息 */
.info-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  text-align: center;
  min-height: 180rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.header {
  margin-bottom: 20rpx;
}

.name {
  font-size: 52rpx;
  font-weight: bold;
  color: #d4a574;
  margin-right: 20rpx;
}

.tag {
  font-size: 28rpx;
  color: #d4a574;
  background: #fff8f0;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.tags {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.tag.generation {
  background: #e6f7ff;
  color: #1890ff;
}

.tag.branch- {
  background: #f6ffed;
  color: #52c41a;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.info-section-light {
  background: #fafafa;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 家庭区块 */
.family-section {
  padding: 24rpx 30rpx;
}

.family-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.family-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.family-label {
  font-size: 28rpx;
  color: #666;
  min-width: 100rpx;
}

.family-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.family-name.clickable {
  color: #1a73e8;
  text-decoration: underline;
}

/* 日期区块 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.dates-section {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.date-item {
  flex: 1;
  min-width: 45%;
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.date-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.date-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* 内容 */
.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 备注区块 */
.remark-section {
  background: #fff9e6;
  border: 1rpx solid #ffe082;
}

.remark-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.remark-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 操作按钮 */
.action-buttons {
  margin-top: auto;
  padding-bottom: 40rpx;
}

.btn {
  width: 100%;
  padding: 30rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

.btn-back {
  background: #f0f0f0;
  color: #666;
}
